# Copy into Render → Web Service → Environment (or local .env). Never commit real secrets.

# --- Gmail (same settings as PHPMailer: smtp.gmail.com, 587, TLS, app password) ---
# Google Account → Security → 2-Step Verification → App passwords → generate one for "Mail".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=your-email@gmail.com

# Optional: where home-page form notifications go (default: solomon.bagambe1011@gmail.com)
# EMAIL_TO=solomon.bagambe1011@gmail.com

# If a host breaks with STARTTLS requirement, set:
# SMTP_REQUIRE_TLS=false

# --- SendGrid (alternative: use SMTP_URL and unset SMTP_HOST) ---
# SMTP_URL=smtps://apikey:SG.YOUR_KEY@smtp.sendgrid.net:465
# EMAIL_FROM=verified-sender@yourdomain.com
