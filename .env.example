# --- Render FREE tier: outbound SMTP (ports 25, 465, 587) is BLOCKED — Gmail will ETIMEDOUT. ---
# Use HTTPS email instead (pick one):

# SendGrid Web API (recommended on Render Free)
# https://app.sendgrid.com → Settings → API Keys → Create (Mail Send scope).
SENDGRID_API_KEY=SG.paste_your_key_here
EMAIL_FROM=your-verified-sender@yourdomain.com

# Or Resend: https://resend.com — API key + a verified "from" (or onboarding@resend.dev for tests)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=onboarding@resend.dev
# EMAIL_FROM=...   # if you omit RESEND_FROM

# Optional: where notifications go (default solomon.bagambe1011@gmail.com)
# EMAIL_TO=solomon.bagambe1011@gmail.com

# --- SMTP (works on local machine, paid Render, or hosts that allow SMTP) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=tls
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password
# EMAIL_FROM=you@gmail.com

# Or SendGrid SMTP URL (still blocked on Render Free — use SENDGRID_API_KEY above)
# SMTP_URL=smtps://apikey:SG.xxx@smtp.sendgrid.net:465
